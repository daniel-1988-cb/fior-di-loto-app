
# ─── META WHATSAPP CLOUD API ─────────────────
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_APP_SECRET=
META_WA_VERIFY_TOKEN=
META_WA_BUSINESS_ACCOUNT_ID=

# ─── BOT INTERNAL ─────────────────────────────
BOT_SEND_BEARER_TOKEN=
GEMINI_API_KEY=

# ─── RESEND (Email transazionale) ─────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ─── VERCEL CRON ──────────────────────────────
# Random secret shared with Vercel cron scheduler. Vercel automatically
# injects `Authorization: Bearer $CRON_SECRET` on scheduled invocations
# when this env var is set. /api/cron/reminders rejects anything that
# doesn't match. Generate with: openssl rand -hex 32
CRON_SECRET=
