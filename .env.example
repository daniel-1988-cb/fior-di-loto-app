
# ─── META WHATSAPP CLOUD API ─────────────────
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_APP_SECRET=
META_WA_VERIFY_TOKEN=
META_WA_BUSINESS_ACCOUNT_ID=

# ─── BOT INTERNAL ─────────────────────────────
BOT_SEND_BEARER_TOKEN=
GEMINI_API_KEY=

# ─── RESEND (Email transazionale) ─────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ─── VERCEL CRON ──────────────────────────────
# Random secret shared with Vercel cron scheduler. Vercel automatically
# injects `Authorization: Bearer $CRON_SECRET` on scheduled invocations
# when this env var is set. /api/cron/reminders rejects anything that
# doesn't match. Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── WHATSAPP TEMPLATES ───────────────────────
# Quando true, fuori dalla finestra customer-care 24h il bot manda i Meta
# Message Templates (UTILITY) invece del free-form. Richiede 4 template
# approvati: fdl_reminder_giorno_prima, fdl_reminder_sera_prima,
# fdl_followup_12h, fdl_followup_24h.
WA_TEMPLATES_ENABLED=false
