{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    { "path": "/api/cron/reminders", "schedule": "0 15 * * *" },
    { "path": "/api/cron/client-segments", "schedule": "0 3 * * *" },
    { "path": "/api/cron/marketing-send", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/marketing-automations", "schedule": "0 9 * * *" }
  ]
}
